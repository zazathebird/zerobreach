  "_comment_email_content_rules": "Content-based signatures for HTML/JS phishing trojans (HTML smuggling, JS redirectors, obfuscated droppers). Applied to the CONTENT of small html/htm/js/hta/vbs/svg/log files found in email-attachment caches (Phase 74.5) and user paths (Phase 90). These match real malicious constructs, NOT antivirus signature NAMES, so they survive renaming and have low false-positive rates.",
  "email_content_rules": [
    { "Name": "HTML_Smuggling_Blob_Download", "Pattern": "(?i)(msSaveOrOpenBlob|msSaveBlob|new\\s+Blob\\s*\\(|URL\\.createObjectURL).{0,400}(\\.(exe|zip|iso|img|vbs|js|hta|rar|7z|cab)|application/octet-stream|application/x-msdownload)", "Severity": "CRITICAL" },
    { "Name": "Base64_Embedded_PE_MZ", "Pattern": "(?i)(atob|fromBase64String|base64[_-]?decode)\\s*\\(\\s*[\"']?\\s*TV(qQ|pQ|oA)", "Severity": "CRITICAL" },
    { "Name": "JS_Obfuscated_Eval_Decoder", "Pattern": "(?i)(eval|setTimeout|Function|document\\.write)\\s*\\(\\s*(atob|unescape|decodeURIComponent|String\\.fromCharCode)\\s*\\(", "Severity": "HIGH" },
    { "Name": "JS_Long_FromCharCode_Chain", "Pattern": "(?i)String\\.fromCharCode\\(\\s*(\\d{1,3}\\s*,\\s*){25,}", "Severity": "HIGH" },
    { "Name": "HTML_Meta_Refresh_Redirect", "Pattern": "(?i)<meta[^>]+http-equiv\\s*=\\s*[\"']?refresh[\"']?[^>]+url\\s*=\\s*(https?:|data:|//)", "Severity": "POSSIBLE" },
    { "Name": "JS_Auto_Window_Location_Redirect", "Pattern": "(?i)(window\\.location(\\.(href|replace|assign))?|document\\.location)\\s*=?\\s*[\"']?(https?:)?//[^\"'\\s]{6,}", "Severity": "POSSIBLE" },
    { "Name": "HTML_Credential_Form_Exfil", "Pattern": "(?i)<form[^>]+action\\s*=\\s*[\"']?https?://[^\"'>]+[^>]*>.{0,600}(type\\s*=\\s*[\"']?password)", "Severity": "HIGH" },
    { "Name": "JS_ActiveX_WScript_Dropper", "Pattern": "(?i)(ActiveXObject\\s*\\(\\s*[\"'](WScript\\.Shell|Scripting\\.FileSystemObject|ADODB\\.Stream|MSXML2\\.XMLHTTP)|WScript\\.Shell.{0,40}\\.Run)", "Severity": "HIGH" },
    { "Name": "URL_Encoded_Payload_Blob", "Pattern": "(?i)(unescape|decodeURIComponent)\\s*\\(\\s*[\"'](%[0-9a-fA-F]{2}){30,}", "Severity": "HIGH" },
    { "Name": "SVG_Embedded_Script_Smuggle", "Pattern": "(?i)<svg[^>]*>.{0,400}<script[^>]*>.{0,400}(atob|eval|fromCharCode|location)", "Severity": "HIGH" }
  ],
