  "_comment_proactive_hardening": "Adversary-informed PROACTIVE safeguards. Each entry is a foothold a real attacker plants/abuses for execution, persistence or privilege escalation. Phase 74.7 audits these even when no active infection is found, so a freshly-cleaned box is hardened against re-infection rather than only scanned reactively.",
  "proactive_persistence_regs": [
    { "Path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run", "Why": "Per-user autorun — #1 commodity-malware persistence" },
    { "Path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce", "Why": "Run-once autorun, often used by droppers" },
    { "Path": "HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run", "Why": "Machine-wide autorun" },
    { "Path": "HKLM:\\Software\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Run", "Why": "32-bit autorun on 64-bit OS" },
    { "Path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Run", "Why": "Explorer policy autorun" },
    { "Path": "HKCU:\\Environment", "Why": "UserInitMprLogonScript logon-script persistence" },
    { "Path": "HKCU:\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Windows", "Why": "Load/Run values execute at logon (legacy but abused)" }
  ],
  "proactive_office_keys": [
    { "Path": "HKCU:\\Software\\Microsoft\\Office\\16.0\\Outlook\\Security", "Name": "Level", "SafeValue": 3, "Why": "Outlook attachment security level — lower = unsafe attachments openable" },
    { "Path": "HKCU:\\Software\\Microsoft\\Office\\16.0\\Word\\Security", "Name": "VBAWarnings", "SafeValue": 2, "Why": "Word macro security — 2 = block macros from internet/email-sourced docs, prompt for local trusted ones (does NOT break legit internal macros)" },
    { "Path": "HKCU:\\Software\\Microsoft\\Office\\16.0\\Excel\\Security", "Name": "VBAWarnings", "SafeValue": 2, "Why": "Excel macro security — 2 = block internet/email-sourced macros, prompt for local trusted ones" },
    { "Path": "HKCU:\\Software\\Microsoft\\Office\\16.0\\Outlook\\Security", "Name": "MarkInternalAsUnsafe", "SafeValue": 1, "Why": "Treat internal-spoofed mail as external" }
  ],
